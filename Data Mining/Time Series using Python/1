import numpy as np


def z_normalize(ts):
    mean = np.mean(ts)
    std = np.std(ts)
    return (ts - mean) / std if std > 0 else np.zeros_like(ts)


def compute_distance_profile(ts, query):
    m = len(query)
    dp_len = len(ts) - m + 1
    dp = np.empty(dp_len)
    query = z_normalize(query)

    for i in range(dp_len):
        dp[i] = np.linalg.norm(z_normalize(ts[i : i + m]) - query)

    return dp


def apply_exclusion(dp, index, m, exclude):
    # Compute the exclusion size
    exclusion_size = int((m * exclude) // 2)
    
    # Define the start and end of the exclusion zone
    start = max(0, index - exclusion_size)
    end = min(len(dp), index + exclusion_size + 1)
    
    # Apply exclusion by setting the values in the exclusion zone to infinity
    dp[start:end] = np.inf


def matrix_profile(ts, m, exclude=0.0):
    n = len(ts)
    mp = np.full(n - m + 1, np.inf)
    mp_idx = np.full(n - m + 1, -1)

    for i in range(n - m + 1):
        query = ts[i : i + m]
        dp = compute_distance_profile(ts, query)
        apply_exclusion(dp, i, m, exclude)

        min_idx = np.argmin(dp)
        mp_idx[i] = min_idx
        mp[i] = dp[min_idx]

    return mp, mp_idx

def find_discords(ts, window, k):
    """Detects the top-k discords in a time series."""
    mp, _ = matrix_profile(ts, window)
    discords = []

    for _ in range(k):
        # Find the index of the highest Matrix Profile value
        discord_idx = np.argmax(mp)
        discords.append(discord_idx)
        
        # Apply exclusion zone: starts at discord_idx and extends for 'window' size
        start = discord_idx
        end = min(len(mp), discord_idx + window)
        mp[start:end] = -np.inf  # Exclude the region after the discord

    return discords
